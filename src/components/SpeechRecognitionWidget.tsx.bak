"use client";

import React, { useState, useRef, useEffect } from "react";
import { Mic, Play, Square, FileText, Upload, Settings } from "lucide-react";
import { motion, AnimatePresence } from "framer-motion";
import { SpeechRecognitionService } from "@/ai/lyrics/SpeechRecognitionService";

interface SpeechRecognitionWidgetProps {
  className?: string;
}

export const SpeechRecognitionWidget: React.FC<SpeechRecognitionWidgetProps> = ({ className = "" }) => {
  const [isRecording, setIsRecording] = useState(false);
  const [isRecognizing, setIsRecognizing] = useState(false);
  const [recognizedText, setRecognizedText] = useState("");
  const [segments, setSegments] = useState<any[]>([]);
  const [selectedModel, setSelectedModel] = useState("whisper-tiny");
  const [language, setLanguage] = useState("auto");
  const [generateSegments, setGenerateSegments] = useState(true);
  const [audioFile, setAudioFile] = useState<File | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [recordingTime, setRecordingTime] = useState(0);
  const [showSettings, setShowSettings] = useState(false);
  const [loadProgress, setLoadProgress] = useState(0);
  
  const audioChunksRef = useRef<Blob[]>([]);
  const mediaRecorderRef = useRef<MediaRecorder | null>(null);
  const recordingTimerRef = useRef<NodeJS.Timeout | null>(null);
  const audioContextRef = useRef<AudioContext | null>(null);
  const speechService = SpeechRecognitionService.getInstance();

  const startRecording = async () => {
    try {
      setError(null);
      const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
      
      const mediaRecorder = new MediaRecorder(stream);
      mediaRecorderRef.current = mediaRecorder;
      audioChunksRef.current = [];
      
      mediaRecorder.ondataavailable = (event) => {
        if (event.data.size > 0) {
          audioChunksRef.current.push(event.data);
        }
      };
      
      mediaRecorder.onstop = () => {
        stream.getTracks().forEach(track => track.stop());
      };
      
      mediaRecorder.start();
      setIsRecording(true);
      setRecordingTime(0);
      
      recordingTimerRef.current = setInterval(() => {
        setRecordingTime(prev => prev + 1);
      }, 1000);
      
    } catch (err) {
      setError(err instanceof Error ? err.message : "Failed to start recording");
    }
  };

  const stopRecording = () => {
    if (mediaRecorderRef.current && isRecording) {
      mediaRecorderRef.current.stop();
      setIsRecording(false);
      
      if (recordingTimerRef.current) {
        clearInterval(recordingTimerRef.current);
      }
    }
  };

  const handleRecognizeRecording = async () => {
    if (audioChunksRef.current.length === 0) return;
    
    setIsRecognizing(true);
    setError(null);
    
    try {
      const audioBlob = new Blob(audioChunksRef.current, { type: "audio/webm" });
      const audioFile = new File([audioBlob], "recording.webm", { type: "audio/webm" });
      
      await recognizeAudioFile(audioFile);
    } catch (err) {
      setError(err instanceof Error ? err.message : "Recognition failed");
    } finally {
      setIsRecognizing(false);
    }
  };

  const handleFileSelect = (e: React.ChangeEvent<HTMLInputElement>) => {
    const file = e.target.files?.[0];
    if (file) {
      setAudioFile(file);
    }
  };

  const getModelId = (model: string) => {
    const modelMap: Record<string, string> = {
      "whisper-tiny": "Xenova/whisper-tiny",
      "whisper-base": "Xenova/whisper-base",
      "paraformer-zh": "Xenova/whisper-tiny",
    };
    return modelMap[model] || "Xenova/whisper-tiny";
  };

  const recognizeAudioFile = async (file: File) => {
    setIsRecognizing(true);
    setError(null);
    
    try {
      if (!audioContextRef.current) {
        audioContextRef.current = new (window.AudioContext || (window as any).webkitAudioContext)();
      }
      
      const arrayBuffer = await file.arrayBuffer();
      const audioBuffer = await audioContextRef.current.decodeAudioData(arrayBuffer);
      
      const modelId = getModelId(selectedModel);
      
      if (!speechService.getIsLoaded()) {
        await speechService.loadModel(modelId, async (progress) => {
          setLoadProgress(progress);
        });
      }
      
      const result = await speechService.transcribeAudio(audioBuffer, async (progress) => {
        setLoadProgress(progress);
      });
      
      if (result.success) {
        setRecognizedText(result.text || "");
        setSegments(result.segments?.map(s => ({
          text: s.text,
          start: s.startTime,
          end: s.endTime,
          confidence: 0.9
        })) || []);
      } else {
        setError(result.error || "Recognition failed");
      }
    } catch (err) {
      setError(err instanceof Error ? err.message : "Recognition failed");
    } finally {
      setIsRecognizing(false);
      setLoadProgress(0);
    }
  };

  const handleRecognizeFile = async () => {
    if (!audioFile) return;
    await recognizeAudioFile(audioFile);
  };

  const formatTime = (seconds: number) => {
    const mins = Math.floor(seconds / 60);
    const secs = seconds % 60;
    return `${mins.toString().padStart(2, "0")}:${secs.toString().padStart(2, "0")}`;
  };

  const clearResult = () => {
    setRecognizedText("");
    setSegments([]);
    setAudioFile(null);
    setError(null);
    setLoadProgress(0);
  };

  return (
    <div className={`bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 ${className}`}>
      <div className="flex items-center justify-between mb-6">
        <h3 className="text-xl font-bold bg-gradient-to-r from-blue-400 to-purple-400 bg-clip-text text-transparent">
          语音识别
        </h3>
        <div className="flex gap-2">
          <button
            onClick={() => setShowSettings(!showSettings)}
            className="p-2 rounded-lg bg-white/10 hover:bg-white/20 transition-all"
            title="设置"
          >
            <Settings className="w-5 h-5" />
          </button>
        </div>
      </div>

      <AnimatePresence mode="wait">
        {showSettings ? (
          <motion.div
            key="settings"
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            className="space-y-4"
          >
            <div>
              <label className="block text-sm font-medium text-white/80 mb-2">
                识别模型
              </label>
              <select
                value={selectedModel}
                onChange={(e) => setSelectedModel(e.target.value)}
                className="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="whisper-tiny">Whisper Tiny (快速)</option>
                <option value="whisper-base">Whisper Base (标准)</option>
                <option value="paraformer-zh">Paraformer (中文)</option>
              </select>
            </div>

            <div>
              <label className="block text-sm font-medium text-white/80 mb-2">
                语言
              </label>
              <select
                value={language}
                onChange={(e) => setLanguage(e.target.value)}
                className="w-full px-3 py-2 rounded-lg bg-white/10 border border-white/20 text-white focus:outline-none focus:ring-2 focus:ring-blue-500"
              >
                <option value="auto">自动检测</option>
                <option value="zh">中文</option>
                <option value="en">English</option>
                <option value="ja">日本語</option>
                <option value="ko">한국어</option>
              </select>
            </div>

            <div className="flex items-center gap-2">
              <input
                type="checkbox"
                id="generate-segments"
                checked={generateSegments}
                onChange={(e) => setGenerateSegments(e.target.checked)}
                className="w-4 h-4 rounded bg-white/10 border-white/20"
              />
              <label htmlFor="generate-segments" className="text-sm text-white/80">
                生成带时间戳的片段
              </label>
            </div>
          </motion.div>
        ) : (
          <motion.div
            key="recognition"
            initial={{ opacity: 0, y: -10 }}
            animate={{ opacity: 1, y: 0 }}
            exit={{ opacity: 0, y: -10 }}
            className="space-y-4"
          >
            {isRecognizing && loadProgress > 0 && (
              <div className="bg-white/5 rounded-lg p-4">
                <div className="text-sm text-white/60 mb-2">加载/识别中... {loadProgress}%</div>
                <div className="h-2 bg-white/10 rounded-full overflow-hidden">
                  <motion.div
                    className="h-full bg-gradient-to-r from-blue-500 to-purple-500"
                    initial={{ width: 0 }}
                    animate={{ width: `${loadProgress}%` }}
                  />
                </div>
              </div>
            )}

            <div className="flex gap-3">
              <button
                onClick={isRecording ? stopRecording : startRecording}
                disabled={isRecognizing}
                className={`flex-1 py-3 px-6 rounded-xl font-medium transition-all flex items-center justify-center gap-2 ${
                  isRecording
                    ? "bg-red-500 hover:bg-red-600"
                    : "bg-gradient-to-r from-blue-500 to-purple-500 hover:from-blue-600 hover:to-purple-600"
                } text-white disabled:opacity-50 disabled:cursor-not-allowed`}
              >
                {isRecording ? (
                  <>
                    <Square className="w-5 h-5" />
                    停止录音 ({formatTime(recordingTime)})
                  </>
                ) : (
                  <>
                    <Mic className="w-5 h-5" />
                    开始录音
                  </>
                )}
              </button>

              {!isRecording && audioChunksRef.current.length > 0 && (
                <button
                  onClick={handleRecognizeRecording}
                  disabled={isRecognizing}
                  className="py-3 px-6 rounded-xl bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium transition-all flex items-center justify-center gap-2"
                >
                  {isRecognizing ? (
                    <>识别中...</>
                  ) : (
                    <>
                      <Play className="w-5 h-5" />
                      识别
                    </>
                  )}
                </button>
              )}
            </div>

            <div className="relative">
              <div className="absolute inset-0 flex items-center">
                <div className="w-full border-t border-white/20" />
              </div>
              <div className="relative flex justify-center">
                <span className="px-4 bg-transparent text-white/50 text-sm">
                  或上传音频文件
                </span>
              </div>
            </div>

            <div className="space-y-3">
              <label className="flex items-center justify-center gap-3 p-4 border-2 border-dashed border-white/20 rounded-xl hover:border-white/30 hover:bg-white/5 transition-all cursor-pointer">
                <Upload className="w-8 h-8 text-white/50" />
                <div>
                  <span className="text-white/80">
                    {audioFile ? audioFile.name : "点击选择音频文件"}
                  </span>
                  {audioFile && (
                    <p className="text-xs text-white/50 mt-1">
                      {(audioFile.size / 1024 / 1024).toFixed(2)} MB
                    </p>
                  )}
                </div>
                <input
                  type="file"
                  accept="audio/*"
                  onChange={handleFileSelect}
                  className="hidden"
                />
              </label>

              {audioFile && (
                <button
                  onClick={handleRecognizeFile}
                  disabled={isRecognizing}
                  className="w-full py-3 px-6 rounded-xl bg-gradient-to-r from-green-500 to-emerald-500 hover:from-green-600 hover:to-emerald-600 disabled:opacity-50 disabled:cursor-not-allowed text-white font-medium transition-all flex items-center justify-center gap-2"
                >
                  {isRecognizing ? (
                    <>识别中...</>
                  ) : (
                    <>
                      <FileText className="w-5 h-5" />
                      识别文件
                    </>
                  )}
                </button>
              )}
            </div>

            {(recognizedText || segments.length > 0) && (
              <div className="space-y-4 pt-4 border-t border-white/10">
                <div className="flex items-center justify-between">
                  <h4 className="text-sm font-medium text-white/80">识别结果</h4>
                  <button
                    onClick={clearResult}
                    className="p-1.5 rounded-lg bg-white/10 hover:bg-white/20 text-white/60 hover:text-white transition-all text-sm"
                  >
                    清除
                  </button>
                </div>

                {segments.length > 0 && (
                  <div className="space-y-2 max-h-60 overflow-y-auto">
                    {segments.map((segment, index) => (
                      <div key={index} className="p-3 rounded-lg bg-white/5 text-sm">
                        <div className="flex items-center gap-2 mb-1">
                          <span className="text-xs text-white/50">
                            {formatTime(Math.floor(segment.start))} - {formatTime(Math.ceil(segment.end))}
                          </span>
                          <span className="text-xs text-white/40">
                            {(segment.confidence * 100).toFixed(0)}%
                          </span>
                        </div>
                        <div className="text-white/90">{segment.text}</div>
                      </div>
                    ))}
                  </div>
                )}

                {recognizedText && (
                  <div className="p-4 rounded-xl bg-white/5 text-white/90 whitespace-pre-wrap">
                    {recognizedText}
                  </div>
                )}
              </div>
            )}

            {error && (
              <div className="p-3 rounded-lg bg-red-500/20 text-red-400 text-sm">
                {error}
              </div>
            )}
          </motion.div>
        )}
      </AnimatePresence>
    </div>
  );
};

export default SpeechRecognitionWidget;
